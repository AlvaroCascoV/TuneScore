@model TuneScore.Models.Song
@using TuneScore.Helpers
@{
    ViewData["Title"] = "Detalles";
}

<h1>Detalles</h1>

<div>
    <h4>Canción</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2">
            Álbum
        </dt>
        <dd class="col-sm-10">
            @if (Model.Album != null)
            {
                <a asp-controller="Albums" asp-action="Details" asp-route-id="@Model.AlbumId">@Model.Album.Title</a>
            }
            else
            {
                @:—
            }
        </dd>
        <dt class="col-sm-2">
            Género
        </dt>
        <dd class="col-sm-10">
            @(Model.Genre?.Name ?? "—")
        </dd>
        <dt class="col-sm-2">
            Duración
        </dt>
        <dd class="col-sm-10">
            @if (Model.DurationSeconds.HasValue)
            {
                @($"{Model.DurationSeconds / 60}:{(Model.DurationSeconds % 60):D2}")
            }
            else
            {
                @:—
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
    </dl>
</div>

<div class="mt-4">
    <h5>Valoraciones</h5>
    <p class="text-muted">Próximamente.</p>
</div>

<div class="mt-3">
    @if (SessionHelper.IsAdmin(Context.Session))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-secondary">Editar</a>
        @:|
    }
    <a asp-action="Index">Volver al listado</a>
</div>
