@model TuneScore.Models.Song

@{
    ViewData["Title"] = "Eliminar";
}

<h1>Eliminar</h1>

<h3>¿Estás seguro de que deseas eliminar esta canción?</h3>
<div>
    <h4>Canción</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2">
            Álbum
        </dt>
        <dd class="col-sm-10">
            @(Model.Album?.Title ?? "—")
        </dd>
        <dt class="col-sm-2">
            Género
        </dt>
        <dd class="col-sm-10">
            @(Model.Genre?.Name ?? "—")
        </dd>
        <dt class="col-sm-2">
            Duración
        </dt>
        <dd class="col-sm-10">
            @if (Model.DurationSeconds.HasValue)
            {
                @($"{Model.DurationSeconds / 60}:{(Model.DurationSeconds % 60):D2}")
            }
            else
            {
                @:—
            }
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Eliminar" class="btn btn-danger" /> |
        <a asp-action="Index">Volver al listado</a>
    </form>
</div>
